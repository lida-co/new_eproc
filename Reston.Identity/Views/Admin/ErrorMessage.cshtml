
@{
    ViewBag.Title = "ErrorMessage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Error Message</h2>

@* 🔒 PERBAIKAN XSS: Gunakan Html.Raw hanya untuk message yang sudah di-encode di controller *@
<h3>
    @Html.Raw(ViewBag.message)
</h3>

@* 🔒 PERBAIKAN XSS: Encode URL untuk mencegah javascript: injection *@
<a href="@Html.AttributeEncode(ViewBag.redir)" rel="noopener noreferrer">Back</a>

